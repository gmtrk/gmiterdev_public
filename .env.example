# Copy to .env (git-ignored) for local development: `cp .env.example .env`
# (`make install` does this automatically if .env is missing.)
# In production, Render sets these in the dashboard with a real Postgres URL.

# Any non-empty value works locally. Generate a real one for prod:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=dev-only-insecure-local-key-change-me

# NOTE (see CLAUDE.md landmine #1): settings.py treats DEBUG as "truthy if set",
# so ANY non-empty value here — even "False" — enables debug mode. Leave as True locally.
DEBUG=True

# Local dev uses a fresh, git-ignored SQLite file (created by `make setup`/`make migrate`).
# The committed db.sqlite3 is an unused skeleton (see CLAUDE.md landmine #3), so we don't touch it.
# Prod uses a Postgres URL, e.g. postgres://USER:PASS@HOST:5432/DBNAME
DATABASE_URL=sqlite:///local.sqlite3

# RAWG API key — ONLY needed to (re)build metaguess/fixtures/games.json via
#   python manage.py build_games_fixture
# Never used at runtime. Get a free key at https://rawg.io/apidocs
RAWG_API_KEY=
